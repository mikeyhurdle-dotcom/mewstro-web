# Teacher dashboard — required on Vercel (Production + Preview + Development)
# Do NOT commit actual values. Set them in the Vercel project dashboard
# under Settings → Environment Variables, then `vercel env pull .env.local`.

# Supabase (shared HobbyPulse project, mewstro_ prefix tables)
NEXT_PUBLIC_SUPABASE_URL=https://nspgvdytqsvnmbitbmey.supabase.co
SUPABASE_SERVICE_ROLE_KEY=... # service_role key from Supabase dashboard

# Student portal (/practice) — anon key only, RLS enforces access.
# This is the same public anon key the iOS app ships in its binary
# (Shared/SharedUtilities/Constants.swift), so it is safe to commit.
# The portal must NEVER touch SUPABASE_SERVICE_ROLE_KEY.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5zcGd2ZHl0cXN2bm1iaXRibWV5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ4NTg0NTAsImV4cCI6MjA5MDQzNDQ1MH0.59CFFp-JfCTsaE96Cy3pKh0aLrXWybyzIj3zJOWfNcI

# Teacher dashboard shared password (demo-level auth for Ellie pilot)
TEACHER_DASHBOARD_PASSWORD=... # pick something simple for the demo

# Postmark — transactional email. Used for the Ellie daily digest and waitlist notifications.
POSTMARK_SERVER_TOKEN=... # Server API token from Postmark dashboard
NOTIFY_EMAIL=mikey@mewstro.com # Where to send new waitlist application alerts

# Base URL for redirects (logout route). Optional — defaults to localhost in dev.
NEXT_PUBLIC_SITE_URL=https://app-landings.vercel.app

# Tealium iQ — account/profile published in TiQ dashboard.
# Loads https://tags.tiqcdn.com/utag/<account>/<profile>/<env>/utag.js at runtime.
# Use 'dev' locally, 'qa' on Vercel preview, 'prod' on production.
NEXT_PUBLIC_TEALIUM_ACCOUNT=services-mikey-gilson
NEXT_PUBLIC_TEALIUM_PROFILE=hobbytracker
NEXT_PUBLIC_TEALIUM_ENVIRONMENT=dev

# ── Stripe teacher billing ───────────────────────────────────────────────
# Everything below ships dark until NEXT_PUBLIC_BILLING_ENABLED="true".
# See Docs/Architecture/Stripe-Billing-Implementation.md (Mewstro repo)
# for the full manual setup checklist.
NEXT_PUBLIC_BILLING_ENABLED=false
STRIPE_SECRET_KEY=... # sk_test_... (test mode) / sk_live_... (live)
STRIPE_WEBHOOK_SECRET=... # whsec_... from the webhook endpoint config
# Price IDs for the four teacher price points (create in Stripe first).
STRIPE_PRICE_STUDIO_MONTHLY=... # price_... £14.99/month
STRIPE_PRICE_STUDIO_ANNUAL=... # price_... £149/year
STRIPE_PRICE_UNLIMITED_MONTHLY=... # price_... £24.99/month
STRIPE_PRICE_UNLIMITED_ANNUAL=... # price_... £249/year
# Optional: promotion code id (promo_...) for the Founding Studios
# 50%-forever coupon — applied automatically when checkout is started
# with founding=true.
STRIPE_FOUNDING_PROMO_ID=...
